{
  "name": "cirvoy-kiro-mcp",
  "version": "1.0.0",
  "description": "MCP Server for bidirectional task synchronization between Kiro IDE and Cirvoy project management system",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "cirvoy-kiro-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "config/example.config.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest --run",
    "test:watch": "vitest",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts"
  },
  "keywords": [
    "mcp",
    "kiro",
    "cirvoy",
    "task-sync",
    "project-management"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "axios": "^1.6.0",
    "express": "^4.18.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "fast-check": "^3.15.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
